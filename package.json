{
  "name": "splendor-web-app",
  "version": "1.0.0",
  "description": "A web application based on the board game Splendor.",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "npm run build && electron .",
    "dist:mac": "npm run build && electron-builder --mac",
    "android:sync": "npm run build && cap sync android",
    "android:open": "npm run build && cap sync android && cap open android"
  },
  "keywords": [
    "splendor",
    "board game",
    "react"
  ],
  "author": "Diego Tartaglia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DiegoTartaglia/Splendor.git"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.diegotartaglia.splendor",
    "productName": "Splendor",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.board-games",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
